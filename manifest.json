{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "0.4.0",
  "default_locale": "fr",

  "browser_specific_settings": {
    "gecko": {
      "id": "apercu-pj@nicolas.local",
      "strict_min_version": "128.0"
    }
  },

  "background": {
    "scripts": ["background/background.js"]
  },

  "permissions": [
    "messagesRead",
    "storage",
    "downloads",
    "downloads.open",
    "compose"
  ],

  "message_display_action": {
    "default_title": "Aperçu PJ — voir les PDF du message",
    "default_icon": {
      "16": "icons/icon.svg",
      "32": "icons/icon.svg"
    }
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    {
      "resources": [
        "viewer/*",
        "vendor/pdfjs/*"
      ],
      "matches": ["*://*/*", "<all_urls>"]
    }
  ],

  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  }
}
